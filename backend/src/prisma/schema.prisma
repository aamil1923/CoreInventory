generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  WAREHOUSE
}

enum OperationStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELED
}

enum MovementType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(WAREHOUSE)
  otpCode   String?
  otpExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id            String          @id @default(uuid())
  name          String
  sku           String          @unique
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  unitOfMeasure String
  reorderLevel  Int             @default(10)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  stockLevels     StockLevel[]
  receiptItems    ReceiptItem[]
  deliveryItems   DeliveryItem[]
  transferItems   TransferItem[]
  adjustments     Adjustment[]
  ledgerEntries   InventoryLedger[]

  @@map("products")
}

model Warehouse {
  id        String     @id @default(uuid())
  name      String
  location  String
  createdAt DateTime   @default(now())
  locations Location[]

  @@map("warehouses")
}

model Location {
  id          String     @id @default(uuid())
  warehouseId String
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  name        String
  createdAt   DateTime   @default(now())

  stockLevels     StockLevel[]
  receiptItems    ReceiptItem[]
  deliveryItems   DeliveryItem[]
  sourceTransfers    TransferItem[] @relation("SourceLocation")
  destTransfers      TransferItem[] @relation("DestLocation")
  adjustments        Adjustment[]
  ledgerEntries      InventoryLedger[]

  @@map("locations")
}

model StockLevel {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
  @@map("stock_levels")
}

model Receipt {
  id        String          @id @default(uuid())
  supplier  String
  status    OperationStatus @default(DRAFT)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     ReceiptItem[]

  @@map("receipts")
}

model ReceiptItem {
  id         String   @id @default(uuid())
  receiptId  String
  receipt    Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Int

  @@map("receipt_items")
}

model Delivery {
  id        String          @id @default(uuid())
  customer  String
  status    OperationStatus @default(DRAFT)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     DeliveryItem[]

  @@map("deliveries")
}

model DeliveryItem {
  id         String   @id @default(uuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Int

  @@map("delivery_items")
}

model Transfer {
  id        String          @id @default(uuid())
  status    OperationStatus @default(WAITING)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id                   String   @id @default(uuid())
  transferId           String
  transfer             Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id])
  quantity             Int
  sourceLocationId     String
  sourceLocation       Location @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destinationLocationId String
  destinationLocation  Location @relation("DestLocation", fields: [destinationLocationId], references: [id])

  @@map("transfer_items")
}

model Adjustment {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  locationId     String
  location       Location @relation(fields: [locationId], references: [id])
  systemQuantity Int
  physicalCount  Int
  quantityChange Int
  reason         String
  createdAt      DateTime @default(now())

  @@map("adjustments")
}

model InventoryLedger {
  id             String       @id @default(uuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id])
  movementType   MovementType
  quantityChange Int
  referenceId    String
  createdAt      DateTime     @default(now())

  @@map("inventory_ledger")
}
